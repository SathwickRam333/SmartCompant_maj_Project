rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    function isOfficer() {
      return isAuthenticated() && (getUserRole() == 'officer' || getUserRole() == 'admin');
    }
    
    function isCitizen() {
      return isAuthenticated() && getUserRole() == 'citizen';
    }

    // Development mode bypass for migration and testing
    function isDevelopment() {
      return true; // Allow in development - will disable in production
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own profile
      // In development, allow reading for email validation and testing
      allow read: if (isAuthenticated() && (isOwner(userId) || isAdmin() || isOfficer())) || isDevelopment();
      
      // Users can create their own profile during registration
      // In development, allow creating any user for testing
      allow create: if (isAuthenticated() && isOwner(userId)) || isDevelopment();
      
      // Users can update their own profile, admins can update any
      // In development, allow updating any user for testing
      allow update: if (isAuthenticated() && (isOwner(userId) || isAdmin())) || isDevelopment();
      
      // Only admins can delete user profiles
      allow delete: if isAdmin();
    }
    
    // Complaints collection
    match /complaints/{complaintId} {
      // Anyone authenticated can read complaints (for public dashboard)
      // In development, allow unauthenticated read for migration/testing
      allow read: if isAuthenticated() || isDevelopment();
      
      // Citizens can create complaints
      allow create: if isAuthenticated() && isCitizen()
        && request.resource.data.citizenId == request.auth.uid;
      
      // Officers and admins can update complaints (status, assignments, etc.)
      // In development, allow unauthenticated update for migration
      allow update: if isOfficer()
        // Citizens can only update feedback on their own complaints
        || (isCitizen() && isOwner(resource.data.citizenId) 
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['feedback']))
        || isDevelopment();
      
      // Only admins can delete complaints
      allow delete: if isAdmin();
    }
    
    // Complaint updates/history (top-level collection)
    match /updates/{updateId} {
      allow read: if isAuthenticated();
      allow create: if isOfficer();
      allow update, delete: if isAdmin();
    }
    
    // Departments collection (read-only for most users)
    match /departments/{departmentId} {
      allow read: if true; // Public read
      allow write: if isAdmin();
    }
    
    // Statistics collection (for dashboard)
    match /statistics/{statId} {
      allow read: if true; // Public read for transparency
      allow write: if isAdmin(); // Only system/admin can update stats
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() 
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isOfficer() || isAdmin();
      allow update: if isAuthenticated() 
        && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
    
    // Settings collection (admin only)
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // AI Classification logs (for audit)
    match /ai_classifications/{logId} {
      allow read: if isOfficer();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // Feedback collection
    match /feedback/{feedbackId} {
      allow read: if isOfficer();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Pending officer registration requests
    match /pending_officer_requests/{requestId} {
      // Unauthenticated users can create requests (they don't have accounts yet)
      allow create: if true;
      
      // In development, allow read for email validation. Otherwise, only admins
      allow read: if isDevelopment() || isAdmin();
      
      // Only admins can update or delete requests, but in development allow it
      allow update, delete: if isDevelopment() || isAdmin();
    }
  }
}
