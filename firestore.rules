rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    function isOfficer() {
      return isAuthenticated() && (getUserRole() == 'officer' || getUserRole() == 'admin');
    }
    
    function isCitizen() {
      return isAuthenticated() && getUserRole() == 'citizen';
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || isOfficer());
      
      // Users can create their own profile during registration
      allow create: if isAuthenticated() && isOwner(userId);
      
      // Users can update their own profile, admins can update any
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      // Only admins can delete user profiles
      allow delete: if isAdmin();
    }
    
    // Complaints collection
    match /complaints/{complaintId} {
      // Anyone authenticated can read complaints (for public dashboard)
      // Sensitive info should be filtered on the client/API level
      allow read: if isAuthenticated();
      
      // Citizens can create complaints
      allow create: if isAuthenticated() && isCitizen()
        && request.resource.data.citizenId == request.auth.uid;
      
      // Officers and admins can update complaints (status, assignments, etc.)
      allow update: if isOfficer()
        // Citizens can only update feedback on their own complaints
        || (isCitizen() && isOwner(resource.data.citizenId) 
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['feedback']));
      
      // Only admins can delete complaints
      allow delete: if isAdmin();
      
      // Subcollection for complaint updates/history
      match /updates/{updateId} {
        allow read: if isAuthenticated();
        allow create: if isOfficer();
        allow update, delete: if isAdmin();
      }
    }
    
    // Departments collection (read-only for most users)
    match /departments/{departmentId} {
      allow read: if true; // Public read
      allow write: if isAdmin();
    }
    
    // Statistics collection (for dashboard)
    match /statistics/{statId} {
      allow read: if true; // Public read for transparency
      allow write: if isAdmin(); // Only system/admin can update stats
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() 
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isOfficer() || isAdmin();
      allow update: if isAuthenticated() 
        && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
    
    // Settings collection (admin only)
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // AI Classification logs (for audit)
    match /ai_classifications/{logId} {
      allow read: if isOfficer();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // Feedback collection
    match /feedback/{feedbackId} {
      allow read: if isOfficer();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
